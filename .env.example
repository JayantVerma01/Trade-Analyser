# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=trade_user
POSTGRES_PASSWORD=trade_pass
POSTGRES_DB=trade_analyser
DATABASE_URL=postgresql://trade_user:trade_pass@localhost:5432/trade_analyser

# ─── MongoDB (optional – for chat logs) ──────────────────────────────────────
MONGO_USER=mongo_user
MONGO_PASSWORD=mongo_pass
MONGODB_URI=mongodb://mongo_user:mongo_pass@localhost:27017/trade_analyser?authSource=admin

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_EXPIRES_IN=7d

# ─── Node.js backend ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000
PYTHON_SERVICE_URL=http://localhost:8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Python AI backend ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-api-key...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# ─── Tavily Web Search (optional — for real-time market news in AI agent) ────
# Get your free key at https://app.tavily.com
TAVILY_API_KEY=tvly-...your-tavily-api-key...

# ─── Next.js frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_NODE_API_URL=http://localhost:3001
NEXT_PUBLIC_PYTHON_API_URL=http://localhost:8000
